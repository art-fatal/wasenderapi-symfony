{
    "name": "wasenderapi/wasenderapi-symfony",
    "description": "Symfony bundle for WasenderAPI – send WhatsApp messages, manage contacts, groups, sessions, and handle webhooks",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "whatsapp", "wasenderapi", "sdk", "bundle", "webhook"],
    "homepage": "https://www.wasenderapi.com",
    "authors": [
        {
            "name": "WasenderAPI",
            "homepage": "https://www.wasenderapi.com"
        }
    ],
    "require": {
        "php": ">=7.3",
        "guzzlehttp/guzzle": "^6.5 || ^7.0",
        "symfony/config": "^4.4 || ^5.0 || ^6.0 || ^7.0",
        "symfony/dependency-injection": "^4.4 || ^5.0 || ^6.0 || ^7.0",
        "symfony/event-dispatcher": "^4.4 || ^5.0 || ^6.0 || ^7.0",
        "symfony/http-foundation": "^4.4 || ^5.0 || ^6.0 || ^7.0",
        "symfony/http-kernel": "^4.4 || ^5.0 || ^6.0 || ^7.0",
        "symfony/routing": "^4.4 || ^5.0 || ^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5 || ^9.0"
    },
    "autoload": {
        "psr-4": {
            "WasenderApi\\SymfonyBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WasenderApi\\SymfonyBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
